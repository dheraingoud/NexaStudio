# ═══════════════════════════════════════════════════════════════════
# NexaStudio Backend - .gitignore
# ═══════════════════════════════════════════════════════════════════

# Compiled class files
*.class

# Log files
*.log
logs/

# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# VS Code
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db

# Environment files (IMPORTANT: Never commit secrets!)
.env
.env.local
.env.*.local
application-local.properties
application-secrets.properties

# H2 Database files
*.db
*.mv.db
*.trace.db

# Temporary files
*.tmp
*.swp
*~

# Generated files
/generated/

# Storage/workspace directories
/storage/
/workspaces/
